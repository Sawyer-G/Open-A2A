FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir --upgrade pip

COPY . /app

# 安装 Relay 所需依赖（使用 pyproject.toml 的 [relay] 可选依赖）
RUN pip install --no-cache-dir ".[relay]"

# 默认环境变量，可被 docker-compose 覆盖
ENV RELAY_WS_HOST=0.0.0.0
ENV RELAY_WS_PORT=8765

CMD ["python", "relay/main.py"]

