## Node X (operator) environment template
#
# Goal: a safer “copy & run” operator node with a minimal required config block.
#
# Recommended: run the guided wizard instead of editing manually:
#   bash scripts/setup-node-x.sh init
#
# Manual usage:
#   cp deploy/node-x/.env.node-x.example .env
#   docker compose -f deploy/node-x/docker-compose.node-x.yml --env-file .env up -d --build

## A) Minimal required (public Node X recommended)
#
# Strict security (fail-fast). Recommended for any public entry node.
OA2A_STRICT_SECURITY=1
#
# Relay (recommended public entry)
RELAY_WS_HOST=0.0.0.0
RELAY_WS_PORT=8765
RELAY_AUTH_TOKEN=change-me
#
# Relay ops endpoint (keep private / localhost only)
RELAY_HTTP_ENABLE=1
RELAY_HTTP_HOST=127.0.0.1
RELAY_HTTP_PORT=8766
#
# Bridge (optional public entry; recommended behind HTTPS reverse proxy)
BRIDGE_PORT=8080
#
# Operator node typically should NOT forward all intents to a single OpenClaw instance.
BRIDGE_ENABLE_FORWARD=0
#
# Directory Registry APIs (register/discover/stats)
BRIDGE_ENABLE_DISCOVERY=1
BRIDGE_DISCOVERY_REGISTER_TOKEN=change-me
BRIDGE_DISCOVERY_DISCOVER_TOKEN=change-me

## B) NATS (internal network; do NOT expose 4222 publicly by default)
NATS_HOST=nats
NATS_PORT=4222

# NATS auth (must match deploy/node-x/nats.conf)
NATS_RELAY_USER=relay
NATS_RELAY_PASS=change-me-relay-pass

NATS_BRIDGE_USER=bridge
NATS_BRIDGE_PASS=change-me-bridge-pass

# Optional: allow direct NATS access for advanced users (not recommended)
NATS_PUBLIC_USER=agent_public
NATS_PUBLIC_PASS=change-me-public-pass

## C) Bridge identity & meta (recommended for public directory-style discovery)
#
# Optional: set a public host (domain/IP) so the setup wizard can build BRIDGE_META_JSON automatically.
# BRIDGE_PUBLIC_HOST=bridge.open-a2a.org
#
# Optional: attach an RFC-004 meta proof so others can verify your meta.
# BRIDGE_ENABLE_META_PROOF=1
# BRIDGE_PUBLIC_URL=https://bridge.open-a2a.org
# BRIDGE_DID_SEED_B64=BASE64_SEED
#
# Operator meta (not secret). For manual mode, set explicitly:
# BRIDGE_AGENT_ID=node-x-bridge
# BRIDGE_CAPABILITIES=intent.food.order,intent.logistics.request
# BRIDGE_META_JSON={"operator":"node-x","region":"global","endpoint":"https://bridge.open-a2a.org"}

## D) Discovery ops (TTL / backend / rate limits)
# BRIDGE_DISCOVERY_DEFAULT_TTL_SECONDS=60
# BRIDGE_DISCOVERY_CLEANUP_INTERVAL_SECONDS=5
# Recommended: Redis backend for directory registry (HA / multi-instance)
# BRIDGE_DISCOVERY_REDIS_URL=redis://redis:6379/0
# Optional: persist directory registry for single-instance restart recovery
# BRIDGE_DISCOVERY_PERSIST_PATH=./data/bridge_discovery_registry.json
# BRIDGE_DISCOVERY_RL_PER_MINUTE=60

## E) Relay tuning (optional)
# RELAY_SUBJECT_ALLOWLIST=intent.>,open_a2a.>,_INBOX.open_a2a.>
# RELAY_SUBJECT_BLOCKLIST=
# RELAY_MAX_SUBSCRIPTIONS_PER_CONN=128
# RELAY_MAX_MESSAGE_BYTES=65536
# RELAY_MAX_JSON_BYTES=262144
# RELAY_RL_PUB_PER_SEC=30

## F) Optional TLS settings for Relay (WSS)
# RELAY_WS_TLS=1
# RELAY_WS_SSL_CERT=/certs/fullchain.pem
# RELAY_WS_SSL_KEY=/certs/privkey.pem
# RELAY_WS_SSL_VERIFY=1

## G) Federation (Option 2): independent NATS + selective subject bridge (optional)
# OA2A_FED_NATS_A=nats://nats-x:4222
# OA2A_FED_NATS_B=nats://nats-y:4222
# OA2A_FED_SUBJECTS=intent.>
# OA2A_FED_BRIDGE_ID=x-y-bridge
# OA2A_FED_MAX_HOPS=1
# OA2A_FED_DEDUPE_TTL_SECONDS=3
# OA2A_FED_DEDUPE_PERSIST_PATH=./data/fed_dedupe.json
# OA2A_FED_DEDUPE_PERSIST_INTERVAL_SECONDS=2
# OA2A_FED_DEDUPE_MAX_ITEMS=50000
# OA2A_FED_STATS_INTERVAL_SECONDS=10
# OA2A_FED_LOG_FORWARD_SAMPLES=0
# OA2A_FED_HTTP_ENABLE=1
# OA2A_FED_HTTP_HOST=127.0.0.1
# OA2A_FED_HTTP_PORT=9464

