# Node X (operator) recommended environment variables
#
# Usage:
#   cp deploy/node-x/.env.node-x.example .env
#   docker compose -f deploy/node-x/docker-compose.node-x.yml --env-file .env up -d --build

# --- Public endpoints / ports (exposed to the Internet) ---

# Relay (recommended public entry)
RELAY_WS_HOST=0.0.0.0
RELAY_WS_PORT=8765

# Relay ops/security (recommended for public nodes)
# RELAY_AUTH_TOKEN=change-me
# RELAY_SUBJECT_ALLOWLIST=intent.>,open_a2a.>,_INBOX.open_a2a.>
# RELAY_SUBJECT_BLOCKLIST=
# RELAY_MAX_SUBSCRIPTIONS_PER_CONN=128
# RELAY_MAX_MESSAGE_BYTES=65536
# RELAY_MAX_JSON_BYTES=262144
# RELAY_RL_PUB_PER_SEC=30

# Bridge (optional public entry; recommended behind HTTPS reverse proxy)
BRIDGE_PORT=8080

# --- Internal network (do NOT expose NATS 4222 to the Internet by default) ---

NATS_HOST=nats
NATS_PORT=4222

# NATS auth (must match deploy/node-x/nats.conf)
NATS_RELAY_USER=relay
NATS_RELAY_PASS=change-me-relay-pass

NATS_BRIDGE_USER=bridge
NATS_BRIDGE_PASS=change-me-bridge-pass

# Optional: if you want to allow direct NATS access for advanced users (not recommended)
NATS_PUBLIC_USER=agent_public
NATS_PUBLIC_PASS=change-me-public-pass

# --- Bridge behavior (operator node defaults) ---

# Operator node typically should NOT forward all intents to a single OpenClaw instance.
BRIDGE_ENABLE_FORWARD=0

# Provide capability registration & discovery API for external Agents/bridges.
BRIDGE_ENABLE_DISCOVERY=1
BRIDGE_AGENT_ID=node-x-bridge
BRIDGE_CAPABILITIES=intent.food.order,intent.logistics.request
BRIDGE_META_JSON={"operator":"node-x","region":"global","endpoint":"http://YOUR_PUBLIC_DOMAIN_OR_IP:8080"}

# Discovery ops (TTL / Auth / Rate limit)
# BRIDGE_DISCOVERY_DEFAULT_TTL_SECONDS=60
# BRIDGE_DISCOVERY_CLEANUP_INTERVAL_SECONDS=5
# Optional: persist directory registry for single-instance restart recovery (disabled by default)
# BRIDGE_DISCOVERY_PERSIST_PATH=./data/bridge_discovery_registry.json
# BRIDGE_DISCOVERY_REGISTER_TOKEN=change-me
# BRIDGE_DISCOVERY_DISCOVER_TOKEN=change-me
# BRIDGE_DISCOVERY_RL_PER_MINUTE=60

# Identity/Trust (RFC-004): sign discovery meta so other nodes can verify it.
# Recommended for public entry nodes that provide directory-style discovery.
#
# If enabled, Bridge will attach:
# - meta.did (did:key)
# - meta.proof (JWS over canonical hash of meta_without_proof)
#
# For stable identity across restarts, set BRIDGE_DID_SEED_B64 and store it securely.
# BRIDGE_ENABLE_META_PROOF=1
# BRIDGE_PUBLIC_URL=https://bridge.open-a2a.org
# BRIDGE_DID_SEED_B64=BASE64_SEED

# --- Optional TLS settings for Relay (WSS) ---
# RELAY_WS_TLS=1
# RELAY_WS_SSL_CERT=/certs/fullchain.pem
# RELAY_WS_SSL_KEY=/certs/privkey.pem
# RELAY_WS_SSL_VERIFY=1

