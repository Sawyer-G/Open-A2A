FROM python:3.12-slim

WORKDIR /app

# Copy only what we need for installation/runtime
COPY pyproject.toml /app/pyproject.toml
COPY open_a2a /app/open_a2a
COPY deploy/dht-bootstrap /app/deploy/dht-bootstrap

RUN pip install --no-cache-dir -e ".[dht]"

EXPOSE 8469

CMD ["python", "/app/deploy/dht-bootstrap/dht_bootstrap_node.py"]

