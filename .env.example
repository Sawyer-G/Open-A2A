# NATS 服务器地址
NATS_URL=nats://localhost:4222

# Merchant 示例的 Agent ID（可选）
MERCHANT_ID=merchant-001

# Phase 2: DID 签名（可选，设为 1 启用）
# USE_IDENTITY=1

# Phase 2: 自托管 Solid Pod 偏好存储（推荐，符合数据主权）
# 需 pip install open-a2a[solid]，详见 docs/zh/08-solid-self-hosted.md
# SOLID_IDP=https://localhost:8443/
# SOLID_POD_ENDPOINT=https://localhost:8443/你的用户名/
# SOLID_USERNAME=你的用户名
# SOLID_PASSWORD=你的密码

# 与 OpenClaw 集成（Bridge 需配置，见 docs/zh/09-deployment-and-openclaw-integration.md）
# OPENCLAW_GATEWAY_URL=http://localhost:3000
# OPENCLAW_HOOKS_TOKEN=your-webhook-token
# BRIDGE_ENABLE_FORWARD=1
# BRIDGE_PORT=8080

# Relay 传输（出站优先，无公网 Agent 连接 Relay 参与网络）
# RELAY_WS_URL=ws://localhost:8765
# RELAY_WS_HOST=0.0.0.0
# RELAY_WS_PORT=8765

# DHT 发现（跨网络）：bootstrap 节点列表，格式 host1:port1,host2:port2
# 所有人使用同一列表即可加入同一 DHT 网，互相发现。未设置时使用内置默认（可为空）。
# OPEN_A2A_DHT_BOOTSTRAP=127.0.0.1:8469
