# NATS 服务器地址
# 本地开发：连接本机 NATS
NATS_URL=nats://localhost:4222
# 或连接公共节点（示例）：nats://user:pass@your-public-ip-or-domain:4222

# Merchant 示例的 Agent ID（可选）
MERCHANT_ID=merchant-001

# Phase 2: DID 签名（可选，设为 1 启用）
# USE_IDENTITY=1

# Phase 2: 自托管 Solid Pod 偏好存储（推荐，符合数据主权）
# 详见 docs/zh/08-solid-self-hosted.md
# 方式一（推荐生产）：OAuth2 客户端凭证，仅用标准库
# SOLID_CLIENT_ID=your-client-id
# SOLID_CLIENT_SECRET=your-client-secret
# SOLID_POD_ENDPOINT=https://localhost:8443/你的用户名/
# SOLID_IDP=https://localhost:8443/   # 可选，用于自动发现 token 端点；或直接设 SOLID_TOKEN_URL
# 方式二：用户名/密码，需 pip install open-a2a[solid]
# SOLID_IDP=https://localhost:8443/
# SOLID_POD_ENDPOINT=https://localhost:8443/你的用户名/
# SOLID_USERNAME=你的用户名
# SOLID_PASSWORD=你的密码

# 与 OpenClaw 集成（Bridge 需配置，见 docs/zh/09-deployment-and-openclaw-integration.md）
# OPENCLAW_GATEWAY_URL=http://localhost:3000
# OPENCLAW_HOOKS_TOKEN=your-webhook-token
# BRIDGE_ENABLE_FORWARD=1
# BRIDGE_PORT=8080

# Bridge 能力发现（持续被发现，目录式 discover）
# Bridge 将使用 NATS Discovery（open_a2a.discovery.query.{capability} 请求-响应）注册能力，
# 只要 Bridge 进程在线，其他节点就能 discover 到该能力的 meta（无需中心化注册表）。
# BRIDGE_ENABLE_DISCOVERY=1
# BRIDGE_AGENT_ID=openclaw-agent
# BRIDGE_CAPABILITIES=intent.food.order,intent.logistics.request
# 可选：补充 meta（JSON 字符串），供发现方展示/路由使用（不要放真实密钥）
# BRIDGE_META_JSON={"region":"shanghai","endpoint":"https://bridge.open-a2a.org"}

# Discovery 产品化（运营级）：TTL/过期回收、访问控制、速率限制
# 默认 TTL（秒），注册方需定期续租（再次调用 register）以保持“在线目录”质量
# BRIDGE_DISCOVERY_DEFAULT_TTL_SECONDS=60
# 清理循环间隔（秒）
# BRIDGE_DISCOVERY_CLEANUP_INTERVAL_SECONDS=5
# 可选：将目录注册表持久化到本地文件（用于单实例重启恢复；为空表示不启用）
# 说明：这是“运营级目录”的补强能力，适合单实例部署；多实例一致性需外部 KV（后续迭代）
# BRIDGE_DISCOVERY_PERSIST_PATH=./data/bridge_discovery_registry.json
# 可选：为注册/查询加 Bearer Token（为空表示不启用鉴权）
# BRIDGE_DISCOVERY_REGISTER_TOKEN=change-me
# BRIDGE_DISCOVERY_DISCOVER_TOKEN=change-me
# 简单速率限制：每分钟每 IP 最大请求数（0 表示不限制）
# BRIDGE_DISCOVERY_RL_PER_MINUTE=60

# Identity/Trust（RFC-004）：为 meta 生成 proof（签名）以支持跨节点验真
# 默认关闭；启用后 Bridge 将尝试生成 did:key 与 meta proof（JWS/Ed25519）。
# BRIDGE_ENABLE_META_PROOF=1
# Bridge 的公网 URL（写入 meta.endpoints，便于展示/路由；非必填）
# BRIDGE_PUBLIC_URL=https://bridge.open-a2a.org
# 可选：固定 Bridge DID（base64 编码 seed，避免重启后 DID 变化；不要提交真实 seed）
# BRIDGE_DID_SEED_B64=BASE64_SEED

# Relay 传输（出站优先，无公网 Agent 连接 Relay 参与网络）
# RELAY_WS_URL=ws://localhost:8765
# 或连接公共 Relay 节点（示例）：ws://relay.open-a2a.org:8765
# RELAY_WS_HOST=0.0.0.0
# RELAY_WS_PORT=8765
# Relay 公网入口建议加“安全阀”（鉴权/配额/主题限制）
# RELAY_AUTH_TOKEN=change-me
# 默认只允许桥接 Open-A2A 核心主题（可按需扩展）
# RELAY_SUBJECT_ALLOWLIST=intent.>,open_a2a.>,_INBOX.open_a2a.>
# RELAY_SUBJECT_BLOCKLIST=
# RELAY_MAX_SUBSCRIPTIONS_PER_CONN=128
# RELAY_MAX_MESSAGE_BYTES=65536
# RELAY_MAX_JSON_BYTES=262144
# RELAY_RL_PUB_PER_SEC=30
# Relay 端到端加密：TLS (wss) 与可选负载加密
# RELAY_WS_TLS=1
# RELAY_WS_SSL_CERT=/path/to/cert.pem
# RELAY_WS_SSL_KEY=/path/to/key.pem
# 客户端连 wss 自签名时可不校验（仅开发/测试）：RELAY_WS_SSL_VERIFY=0
# 负载 E2E（Relay 不可见明文）：通信双方配置相同密钥，pip install open-a2a[e2e]
# OPEN_A2A_RELAY_PAYLOAD_SECRET=your-shared-secret

# DHT 发现（跨网络）：bootstrap 节点列表，格式 host1:port1,host2:port2
# 所有人使用同一列表即可加入同一 DHT 网，互相发现。未设置时使用内置默认（可为空）。
# OPEN_A2A_DHT_BOOTSTRAP=127.0.0.1:8469
